# Environment variables for autocommit
# Override default prefix: e.g., "[auto]"
AUTOCOMMIT_PREFIX=Auto-commit:
# Short mode template: {files} = comma-separated files, {count} = total count
AUTOCOMMIT_SHORT_TEMPLATE={files}{count,?+: {count} files}
# Long message footer
AUTOCOMMIT_INCLUDE_DIFF_STAT=true
